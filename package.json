{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "fumadocs-mdx && next dev",
    "dev:watch": "fumadocs-mdx --watch & next dev",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "export": "next build && next export",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint content/**/*.md content/**/*.mdx",
    "lint:md:fix": "markdownlint --fix content/**/*.md content/**/*.mdx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run lint:md",
    "validate:fix": "npm run type-check && npm run lint:fix && npm run lint:md:fix && npm run format",
    "content:build": "fumadocs-mdx",
    "content:dev": "fumadocs-mdx --watch",
    "preview": "npm run build && npm run start",
    "clean": "rimraf .next out",
    "check-links": "node scripts/check-links.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "sync-docs": "node scripts/sync-docs.js"
  },
  "dependencies": {
    "@types/prismjs": "^1.26.6",
    "fumadocs-core": "^16.8.11",
    "fumadocs-mdx": "^15.0.6",
    "fumadocs-ui": "^16.8.11",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "prismjs": "^1.30.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "glob": "^13.0.6",
    "markdownlint-cli": "^0.48.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
